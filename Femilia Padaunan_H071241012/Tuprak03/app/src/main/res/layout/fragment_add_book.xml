<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1D"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Buku Baru"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <ImageView
            android:id="@+id/ivCoverBuku"
            android:layout_width="140dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="#D9D9D9"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnPilihCover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:backgroundTint="#D1B3FF"
            android:text="Pilih Cover dari Galeri"
            android:textAllCaps="false"
            android:textColor="#333333"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/etJudul"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#888888"
            android:hint="Judul Buku"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etPenulis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#888888"
            android:hint="Penulis"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etSinopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#888888"
            android:gravity="top|start"
            android:hint="Sinopsis Singkat"
            android:inputType="textMultiLine"
            android:lines="4"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#4CAF50"
            android:text="Simpan Buku"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>